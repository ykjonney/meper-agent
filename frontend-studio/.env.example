# VITE_API_BASE_URL: base URL for all backend API requests.
# In dev, the vite proxy forwards /api to http://localhost:8000, so a relative
# path works. For production builds, set this to the backend origin
# (e.g. https://api.example.com/api/v1).
VITE_API_BASE_URL="/api/v1"

# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"
