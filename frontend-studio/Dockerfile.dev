# syntax=docker/dockerfile:1.7

# Development image for frontend-studio - runs Vite dev server with HMR
FROM node:22-alpine

WORKDIR /app

# Copy package files
COPY package.json package-lock.json ./
RUN npm ci

# Copy source
COPY . .

# Expose Vite dev server port (frontend-studio uses 3000)
EXPOSE 3000

# Run Vite dev server
CMD ["npm", "run", "dev"]
