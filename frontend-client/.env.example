VITE_API_BASE=/api
VITE_STREAM_BASE=

# 无状态访客模式：填入 API Key（af_live_xxx）即启用，留空则走 JWT 登录。
# 该 Key 的 user_info_url 决定终端用户认证方式：
#   空   → legacy 匿名模式（前端生成 visitor_id）
#   有值 → callback 回调模式（需宿主页 postMessage 注入 X-User-Token）
VITE_PUBLIC_API_KEY=

# callback 模式：允许向本页 postMessage 注入 X-User-Token 的父页 origin 白名单（逗号分隔）
VITE_ALLOWED_PARENT_ORIGINS=
