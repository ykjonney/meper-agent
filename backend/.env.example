# Application
APP_NAME=Agent Flow
APP_ENV=development
DEBUG=true

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=agent_flow

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO
LOG_JSON_FORMAT=false

# Model API Key encryption (Base64-encoded 32-byte AES-256 key)
# Generate: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
MODEL_ENCRYPTION_KEY=

# ── Sandbox (Docker-based bash execution) ─────────────────────────────
# Set SANDBOX_ENABLED=true to run bash commands inside Docker containers.
# When false (default), bash runs via subprocess (suitable for local dev).
SANDBOX_ENABLED=false
SANDBOX_IMAGE=agent-sandbox:latest
SANDBOX_MEM_LIMIT=512m
SANDBOX_CPU_QUOTA=100000
SANDBOX_TIMEOUT=120
SANDBOX_MAX_OUTPUT_BYTES=51200

# Network mode for sandbox containers.
# "none"   = no network access (most secure, default)
# "bridge" = standard Docker bridge network (allows outbound internet)
# "host"   = use host network stack (least isolation)
SANDBOX_NETWORK_MODE=none

# Host-side paths for volume mounts (only needed when backend runs inside a container).
# Leave empty when backend runs directly on the host.
SANDBOX_HOST_WORKSPACES_DIR=
SANDBOX_HOST_SKILLS_DIR=

# Container-internal mount points (usually don't need to change).
SANDBOX_CONTAINER_WORKSPACE_DIR=/workspace
SANDBOX_CONTAINER_SKILLS_DIR=/data/skills
