# Caddy configuration for Agent Flow
# Serves frontend static files, widget JS, and reverse proxies API

:80 {
	# Frontend static files root
	root * /srv

	# Backend API proxy (must be before try_files)
	@api path /api/*
	handle @api {
		reverse_proxy backend:8000
	}

	# WebSocket proxy
	@ws path /ws/*
	handle @ws {
		reverse_proxy backend:8000
	}

	# Widget JS — serve directly, no SPA fallback
	@widget path /static/*
	handle @widget {
		file_server
	}

	# Static files (try file first, then fall back to index.html for SPA)
	handle {
		try_files {path} /index.html
		file_server
	}

	# Logging
	log {
		output stdout
	}

	# Gzip compression
	encode gzip
}
