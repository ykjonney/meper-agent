# Caddy configuration for Agent Flow
# Serves frontend-studio (management) + frontend-client (end-user) + reverse proxies API

:80 {
	# Frontend static files root (frontend-studio at /)
	root * /srv

	# Backend API proxy (must be before try_files)
	@api path /api/*
	handle @api {
		reverse_proxy backend:8000
	}

	# WebSocket proxy
	@ws path /ws/*
	handle @ws {
		reverse_proxy backend:8000
	}

	# frontend-client (end-user app) — SPA with index.html fallback
	@client path /client/*
	handle @client {
		root * /srv
		uri strip_prefix /client
		try_files {path} /client/index.html
		file_server
	}

	# Static files (try file first, then fall back to index.html for SPA)
	handle {
		try_files {path} /index.html
		file_server
	}

	# Logging
	log {
		output stdout
	}

	# Gzip compression
	encode gzip
}
