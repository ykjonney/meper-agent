# Caddy configuration for Agent Flow
# Serves frontend static files and reverse proxies API

:80 {
	# Frontend static files
	root * /srv

	# Backend API proxy
	reverse_proxy /api/* backend:8000

	# WebSocket proxy
	reverse_proxy /ws/* backend:8000

	# SPA fallback: try file first, then fall back to index.html
	try_files {path} /index.html

	# Serve files (with SPA fallback support)
	file_server

	# Logging
	log {
		output stdout
	}

	# Gzip compression
	encode gzip
}
