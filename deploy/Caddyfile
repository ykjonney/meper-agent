# Caddy configuration for Agent Flow
# Serves frontend static files and reverse proxies API

:80 {
	# Frontend static files
	root * /srv
	file_server

	# Backend API proxy
	reverse_proxy /api/* backend:8000

	# WebSocket proxy
	reverse_proxy /ws/* backend:8000

	# SPA fallback: serve index.html for non-file routes
	try_files /index.html

	# Logging
	log {
		output stdout
	}

	# Gzip compression
	encode gzip
}
