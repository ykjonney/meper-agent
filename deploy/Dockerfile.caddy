# syntax=docker/dockerfile:1.7

# --- Stage 1: Build frontend-studio (management console) ---
FROM node:22-alpine AS frontend-builder

WORKDIR /app

COPY frontend-studio/package.json frontend-studio/package-lock.json ./
RUN npm ci

COPY frontend-studio/ ./
RUN npm run build

# --- Stage 2: Build frontend-client (end-user chat app) ---
FROM node:22-alpine AS client-builder

WORKDIR /app

COPY frontend-client/package.json frontend-client/package-lock.json* ./
RUN npm ci

COPY frontend-client/ ./
RUN npm run build

# --- Stage 3: Caddy serving frontends + reverse proxy ---
FROM caddy:2-alpine

# Copy built frontend-studio assets (management console, served at root)
COPY --from=frontend-builder /app/dist /srv

# Copy built frontend-client assets (end-user app, served at /client/)
COPY --from=client-builder /app/dist /srv/client

# Copy Caddyfile
COPY deploy/Caddyfile /etc/caddy/Caddyfile

EXPOSE 80
EXPOSE 443

CMD ["caddy", "run", "--config", "/etc/caddy/Caddyfile", "--adapter", "caddyfile"]
