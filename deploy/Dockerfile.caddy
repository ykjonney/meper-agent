# syntax=docker/dockerfile:1.7

# --- Stage 1: Build chat widget ---
FROM node:22-alpine AS widget-builder

WORKDIR /app

COPY agent-flow-widget/package.json agent-flow-widget/package-lock.json* ./
RUN npm ci

COPY agent-flow-widget/ ./
RUN npm run build

# --- Stage 2: Build frontend-studio ---
FROM node:22-alpine AS frontend-builder

WORKDIR /app

COPY frontend-studio/package.json frontend-studio/package-lock.json ./
RUN npm ci

COPY frontend-studio/ ./
RUN npm run build

# --- Stage 3: Caddy serving frontend + widget + reverse proxy ---
FROM caddy:2-alpine

# Copy built frontend assets
COPY --from=frontend-builder /app/dist /srv

# Copy built widget JS
COPY --from=widget-builder /app/dist/agent-chat.js /srv/static/agent-chat.js

# Copy Caddyfile
COPY deploy/Caddyfile /etc/caddy/Caddyfile

EXPOSE 80
EXPOSE 443

CMD ["caddy", "run", "--config", "/etc/caddy/Caddyfile", "--adapter", "caddyfile"]
