# Deploy environment variables — copy to .env and fill in values
# NEVER commit the real .env file to version control.

# Application
APP_NAME=Agent Flow
APP_ENV=production
DEBUG=false

# MongoDB
MONGODB_URI=mongodb://agentflow:changeme@mongodb:27017/agent_flow?authSource=admin
MONGODB_DB_NAME=agent_flow
MONGO_ROOT_USER=agentflow
MONGO_ROOT_PASSWORD=changeme

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=CHANGE-ME-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# CORS
CORS_ORIGINS=http://localhost,http://localhost:5173

# Logging
LOG_LEVEL=INFO
LOG_JSON_FORMAT=true

# Admin user (for initial setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_EMAIL=admin@example.com

# ── Data directories ──────────────────────────────────────────────────
# Host-side ABSOLUTE paths for persistent data (used by Docker bind mounts).
# These are the paths on the HOST machine where data is stored.
# IMPORTANT: Use absolute paths! Relative paths may not resolve correctly
# when the backend spawns sandbox containers via Docker socket.
# ${PWD} is resolved by docker-compose when starting services.
WORKSPACES_HOST_DIR=${PWD}/data/workspaces
SKILLS_HOST_DIR=${PWD}/data/skills
MONGODB_DATA_DIR=${PWD}/data/mongodb
REDIS_DATA_DIR=${PWD}/data/redis

# Container-internal paths (where host dirs are mounted inside backend container).
# Backend code uses these to access files. Usually don't need to change.
WORKSPACES_CONTAINER_DIR=/data/workspaces
SKILLS_CONTAINER_DIR=/data/skills

WORKSPACE_MAX_BYTES=524288000

# Sandbox (bash tool isolation)
SANDBOX_ENABLED=true
SANDBOX_IMAGE=agent-sandbox:latest
SANDBOX_MEM_LIMIT=512m
SANDBOX_CPU_QUOTA=100000
SANDBOX_TIMEOUT=120
SANDBOX_MAX_OUTPUT_BYTES=51200
# Network mode: "none" (secure), "bridge" (internet access), "host" (least isolation)
SANDBOX_NETWORK_MODE=bridge
# Container-internal mount points (inside the sandbox container).
# These define where workspace/skill dirs appear inside the sandbox.
SANDBOX_CONTAINER_WORKSPACE_DIR=/workspace
SANDBOX_CONTAINER_SKILLS_DIR=/data/skills

# ── Docker images ──────────────────────────────────────────────────
# For production deployment with ACR (Alibaba Cloud Container Registry):
# BACKEND_IMAGE=crpi-xxx.cn-hangzhou.personal.cr.aliyuncs.com/agent-flow/agent-flow-backend:latest
# CADDY_IMAGE=crpi-xxx.cn-hangzhou.personal.cr.aliyuncs.com/agent-flow/agent-flow-caddy:latest
# SANDBOX_IMAGE=crpi-xxx.cn-hangzhou.personal.cr.aliyuncs.com/agent-flow/agent-flow-sandbox:latest
#
# For local development, leave as default (will build from Dockerfile)
# BACKEND_IMAGE=deploy-backend
# CADDY_IMAGE=deploy-caddy
# SANDBOX_IMAGE=agent-sandbox:latest
