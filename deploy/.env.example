# Deploy environment variables — copy to .env and fill in values
# NEVER commit the real .env file to version control.

# Application
APP_NAME=Agent Flow
APP_ENV=production
DEBUG=false

# MongoDB
MONGODB_URI=mongodb://agentflow:changeme@mongodb:27017/agent_flow?authSource=admin
MONGODB_DB_NAME=agent_flow
MONGO_ROOT_USER=agentflow
MONGO_ROOT_PASSWORD=changeme

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=CHANGE-ME-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# CORS
CORS_ORIGINS=http://localhost,http://localhost:5173

# Logging
LOG_LEVEL=INFO
LOG_JSON_FORMAT=true

# Admin user (for initial setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_EMAIL=admin@example.com

# Sandbox (bash tool isolation)
SANDBOX_ENABLED=true
SANDBOX_IMAGE=agent-sandbox:latest
SANDBOX_MEM_LIMIT=512m
SANDBOX_TIMEOUT=120
# Host-side path prefix for Docker volume mounts.
# Required when backend runs inside a container — Docker daemon needs
# host paths, not container-internal paths.
# Example: SANDBOX_HOST_WORKSPACES_DIR=/home/user/project/deploy/data/workspaces
SANDBOX_HOST_WORKSPACES_DIR=
SANDBOX_HOST_SKILLS_DIR=
