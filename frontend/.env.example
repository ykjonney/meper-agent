# Frontend environment variables (Vite)
# Copy this file to `.env` and adjust values for your local environment.
#
# IMPORTANT: In dev, leave these EMPTY (commented out). The Vite proxy
# (vite.config.ts) forwards /api and /ws to the backend, and a relative
# baseURL works whether you access via localhost, an IP, or a domain.
# Setting http://localhost:8000 here BREAKS non-localhost access because the
# browser will try to reach localhost on the VISITOR's machine.

# API base URL — leave empty in dev. Set to an absolute origin only for prod
# builds (e.g. https://api.example.com). Empty = relative paths (use proxy).
# VITE_API_BASE_URL=

# WebSocket base URL — derived from the page location by default, so no config
# is needed. Override only for prod (e.g. wss://api.example.com).
# VITE_WS_BASE_URL=

# Dev-only: the backend target the Vite proxy forwards /api and /ws to.
# Defaults to http://localhost:8000. In docker-compose dev, set to
# http://backend:8000.
# VITE_API_TARGET=http://localhost:8000
